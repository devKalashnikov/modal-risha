# Strict allowlist: ignore everything at root, un-ignore the minimum
# needed for a teammate to run `modal deploy modal_comfyui.py` and
# `modal deploy modal_judge.py` from a fresh clone.

/*

!/.gitignore
!/README.md
!/modal_comfyui.py
!/modal_judge.py
!/modal_video.py
!/extra_model_paths.yaml
!/custom_nodes/
!/orchestrator/
!/user-uploads/

# Inside custom_nodes/  ->  only the Risha node pack
/custom_nodes/*
!/custom_nodes/risha_nodes/

# Inside orchestrator/  ->  only the rubrics dir
/orchestrator/*
!/orchestrator/rubrics/

# Inside user-uploads/  ->  only the plan CSV, no source images
/user-uploads/*
!/user-uploads/qareeb_keyframes.csv

# workflows/ — only the finalized motion-engine API workflows ship.
# T2I + Edit workflows still being tuned; add them here when ready.
!/workflows/
/workflows/*
!/workflows/motion_kenburns.api.json
!/workflows/motion_static_slide.api.json
# LTX-2.3 22B distilled fp8 FLF (graph form, load via the UI)
!/workflows/wan_flf_test.api.json
!/workflows/video_ltx2_3_flf2v.json

# Common noise that should never be tracked even inside allowed dirs
**/__pycache__/
**/*.pyc
**/*.pyo
**/.DS_Store
**/Thumbs.db
**/.venv/
**/venv/
**/.env
**/.env.*
.idea/
.vscode/
